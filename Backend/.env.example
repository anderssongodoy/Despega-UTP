APP_NAME=Despega UTP API
APP_ENV=local
# Ajusta usuario/clave/puerto de tu PostgreSQL. La base debe llamarse despega_utp.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/despega_utp
CORS_ORIGINS=http://localhost:4200,http://localhost:5173,http://127.0.0.1:4200,http://127.0.0.1:5173

# OPCIONAL — solo habilita las funciones con IA (análisis de CV en PDF y coach de pitch).
# Si lo dejas vacío, el backend arranca igual y el resto de la app funciona normal.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
